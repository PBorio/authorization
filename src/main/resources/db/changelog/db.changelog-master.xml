<databaseChangeLog
xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd
http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

    <changeSet author="Paulo" id="initial-1">
        <createTable tableName="roles">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(32)"/>
        </createTable>
        <insert tableName="roles">
            <column  name="name"  value="Rsystem-admin"/>
        </insert>
        <insert tableName="roles">
            <column  name="name"  value="company-admin"/>
        </insert>
        <insert tableName="roles">
            <column  name="name"  value="user"/>
        </insert>

        <createTable tableName="users">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="email" type="VARCHAR(255)"/>
            <column name="password" type="VARCHAR(255)"/>
            <column name="enabled" type="boolean"/>
        </createTable>

        <addNotNullConstraint columnName="email"
                              constraintName="nn_user_mail"
                              tableName="users"/>

        <addNotNullConstraint columnName="password"
                              constraintName="nn_user_pass"
                              tableName="users"/>

        <createTable tableName="users_roles">
            <column name="user_id" type="BIGINT"/>
            <column name="role_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="users_roles"
                                 constraintName="fk_usr_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>

        <addNotNullConstraint columnName="user_id"
                              constraintName="nn_ur_user_id"
                              tableName="users_roles"/>

        <addNotNullConstraint columnName="role_id"
                              constraintName="nn_ur_role_id"
                              tableName="users_roles"/>

        <addForeignKeyConstraint baseColumnNames="role_id"
                                 baseTableName="users_roles"
                                 constraintName="fk_usr_role_id"
                                 referencedColumnNames="id"
                                 referencedTableName="roles"/>

        <createTable tableName="verification_token">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="token" type="VARCHAR(255)"/>
            <column name="expire_date" type="datetime"/>
            <column name="user_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="verification_token"
                                 constraintName="fk_vtk_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>

        <addNotNullConstraint columnName="token"
                              constraintName="nn_token"
                              tableName="verification_token"/>

        <createTable tableName="companies">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="alias" type="VARCHAR(16)"/>
            <column name="user_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="companies"
                                 constraintName="fk_co_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>

        <addNotNullConstraint columnName="name"
                              constraintName="nn_company_name"
                              tableName="companies"/>

        <createTable tableName="customers">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="address" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(32)"/>
            <column name="phone_number" type="VARCHAR(32)"/>
            <column name="company_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="company_id"
                                 baseTableName="customers"
                                 constraintName="fk_cus_com_id"
                                 referencedColumnNames="id"
                                 referencedTableName="companies"/>

        <addNotNullConstraint columnName="name"
                              constraintName="nn_customer_name"
                              tableName="customers"/>

        <addNotNullConstraint columnName="company_id"
                              constraintName="nn_customer_company_id"
                              tableName="customers"/>

        <createTable tableName="proposals">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="observation" type="VARCHAR(255)"/>
            <column name="value" type="NUMERIC(10,2)"/>
            <column name="company_id" type="BIGINT"/>
            <column name="customer_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="company_id"
                                 baseTableName="proposals"
                                 constraintName="fk_com_prop_id"
                                 referencedColumnNames="id"
                                 referencedTableName="companies"/>

        <addNotNullConstraint columnName="description"
                              constraintName="nn_description"
                              tableName="proposals"/>

        <addNotNullConstraint columnName="company_id"
                              constraintName="nn_proposal_company_id"
                              tableName="proposals"/>

        <addForeignKeyConstraint baseColumnNames="customer_id"
                                 baseTableName="proposals"
                                 constraintName="fk_cus_prop_id"
                                 referencedColumnNames="id"
                                 referencedTableName="customers"/>

        <addNotNullConstraint columnName="customer_id"
                              constraintName="nn_proposal_customer_id"
                              tableName="proposals"/>

        <createTable tableName="proposal_service_item">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints primaryKey="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="observation" type="VARCHAR(255)"/>
            <column name="value" type="NUMERIC(10,2)"/>
            <column name="proposal_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="proposal_id"
                                 baseTableName="proposal_service_item"
                                 constraintName="fk_psi_prop_id"
                                 referencedColumnNames="id"
                                 referencedTableName="proposals"/>

        <addNotNullConstraint columnName="description"
                              constraintName="nn_psi_description"
                              tableName="proposal_service_item"/>

        <addNotNullConstraint columnName="proposal_id"
                              constraintName="nn_psi_proposal_id"
                              tableName="proposal_service_item"/>

    </changeSet>
    <changeSet author="Paulo" id="addBlobToCompany">
        <addColumn tableName="companies" >
            <column name="logo"
                    type="BLOB"/>
        </addColumn>
    </changeSet>


</databaseChangeLog>